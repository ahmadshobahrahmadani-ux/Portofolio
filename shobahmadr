<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Portfolio — Ahmad Shobah Rahmadani</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css" />
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --bg: #ffffff;
      --bg-secondary: #f6f6f4;
      --text-primary: #1a1a1a;
      --text-secondary: #6b6b68;
      --text-tertiary: #9a9a96;
      --border: rgba(0, 0, 0, 0.1);
      --border-md: rgba(0, 0, 0, 0.18);
      --accent: #185FA5;
      --accent-bg: #E6F1FB;
      --accent-text: #0C447C;
      --radius-md: 8px;
      --radius-lg: 12px;
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #1c1c1a;
        --bg-secondary: #252523;
        --text-primary: #f0efe8;
        --text-secondary: #a0a09a;
        --text-tertiary: #686864;
        --border: rgba(255, 255, 255, 0.1);
        --border-md: rgba(255, 255, 255, 0.18);
        --accent: #378ADD;
        --accent-bg: #042C53;
        --accent-text: #85B7EB;
      }
    }

    html {
      font-size: 16px;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
      background: var(--bg);
      color: var(--text-primary);
      line-height: 1.7;
      padding: 0 1rem;
    }

    .port {
      max-width: 680px;
      margin: 0 auto;
      padding-bottom: 4rem;
    }

    /* ── Hero ── */
    .hero {
      padding: 3.5rem 0 2.5rem;
      border-bottom: 0.5px solid var(--border);
      position: relative;
    }

    .hero-tag {
      font-size: 11px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-tertiary);
      margin-bottom: 1rem;
    }

    .hero-name {
      font-size: 38px;
      font-weight: 500;
      line-height: 1.15;
      margin-bottom: 0.5rem;
      /* leave room for avatar on the right */
      padding-right: 90px;
    }

    .hero-role {
      font-size: 15px;
      color: var(--text-secondary);
      margin-bottom: 1.5rem;
      line-height: 1.7;
    }

    .hero-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .badge {
      font-size: 12px;
      padding: 4px 11px;
      border: 0.5px solid var(--border-md);
      border-radius: 999px;
      color: var(--text-secondary);
      display: inline-flex;
      align-items: center;
      gap: 5px;
    }

    /* ── Avatar ── */
    .hero-avatar {
      position: absolute;
      top: 3.5rem;
      right: 0;
      width: 72px;
      height: 72px;
      border-radius: 50%;
      overflow: hidden;
      border: 2px solid var(--border-md);
      background: var(--bg-secondary);
      flex-shrink: 0;
    }

    .hero-avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .hero-avatar-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text-tertiary);
      font-size: 32px;
    }

    /* ── Sections ── */
    .section {
      padding: 2rem 0;
      border-bottom: 0.5px solid var(--border);
    }

    .section:last-of-type {
      border-bottom: none;
    }

    .sec-label {
      font-size: 11px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-tertiary);
      margin-bottom: 1.25rem;
    }

    /* ── About ── */
    .about-text {
      font-size: 14px;
      color: var(--text-secondary);
      line-height: 1.8;
    }

    /* ── Education ── */
    .edu-row {
      display: flex;
      align-items: flex-start;
      gap: 14px;
    }

    .edu-icon {
      width: 36px;
      height: 36px;
      border-radius: var(--radius-md);
      background: var(--bg-secondary);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      font-size: 18px;
      color: var(--text-secondary);
    }

    .edu-body {
      flex: 1;
    }

    .edu-name {
      font-size: 13px;
      font-weight: 500;
      margin-bottom: 2px;
    }

    .edu-detail {
      font-size: 12px;
      color: var(--text-secondary);
      line-height: 1.7;
    }

    .edu-gpa {
      display: inline-block;
      margin-top: 4px;
      font-size: 11px;
      padding: 2px 9px;
      border-radius: 999px;
      background: var(--accent-bg);
      color: var(--accent-text);
    }

    /* ── Skills ── */
    .skills-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 10px;
    }

    .skill-card {
      background: var(--bg-secondary);
      border-radius: var(--radius-md);
      padding: 0.75rem 1rem;
    }

    .skill-cat {
      font-size: 10px;
      color: var(--text-tertiary);
      margin-bottom: 6px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .skill-items {
      font-size: 13px;
      color: var(--text-primary);
      line-height: 1.9;
    }

    /* ── Projects ── */
    .project-list {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .proj-card {
      background: var(--bg);
      border: 0.5px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 1rem 1.25rem;
    }

    .proj-card img {
      width: 100%;
      height: auto;
      max-height: 320px;
      object-fit: cover;
      border-radius: var(--radius-md);
      margin: 12px 0;
      border: 0.5px solid var(--border);
      display: block;
    }

    .proj-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 6px;
    }

    .proj-title {
      font-size: 14px;
      font-weight: 500;
    }

    .proj-tag {
      font-size: 11px;
      padding: 2px 9px;
      border-radius: 999px;
      background: var(--accent-bg);
      color: var(--accent-text);
      white-space: nowrap;
      flex-shrink: 0;
    }

    .proj-desc {
      font-size: 13px;
      color: var(--text-secondary);
      line-height: 1.65;
      margin-bottom: 10px;
    }

    /* Bullet list inside project cards */
    .proj-duties {
      list-style: none;
      padding: 0;
      margin: 0 0 10px;
    }

    .proj-duties li {
      font-size: 12px;
      color: var(--text-secondary);
      line-height: 1.7;
      padding-left: 12px;
      position: relative;
    }

    .proj-duties li::before {
      content: '·';
      position: absolute;
      left: 0;
      color: var(--text-tertiary);
    }

    /* Tech pills */
    .proj-stack {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .stack-pill {
      font-size: 11px;
      padding: 2px 8px;
      border: 0.5px solid var(--border);
      border-radius: 4px;
      color: var(--text-secondary);
    }

    /* ── Organisations ── */
    .org-list {
      display: flex;
      flex-direction: column;
    }

    .org-row {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      padding: 0.85rem 0;
      border-bottom: 0.5px solid var(--border);
    }

    .org-row:last-child {
      border-bottom: none;
    }

    .org-icon {
      width: 36px;
      height: 36px;
      border-radius: var(--radius-md);
      background: var(--bg-secondary);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      font-size: 18px;
      color: var(--text-secondary);
    }

    .org-body {
      flex: 1;
    }

    .org-name {
      font-size: 13px;
      font-weight: 500;
      margin-bottom: 2px;
    }

    .org-role {
      font-size: 12px;
      color: var(--text-secondary);
      margin-bottom: 6px;
    }

    .org-duties {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .org-duties li {
      font-size: 12px;
      color: var(--text-secondary);
      line-height: 1.7;
      padding-left: 12px;
      position: relative;
    }

    .org-duties li::before {
      content: '·';
      position: absolute;
      left: 0;
      color: var(--text-tertiary);
    }

    /* ── Contact ── */
    .contact-row {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 13px;
      color: var(--text-secondary);
      margin-bottom: 10px;
    }

    .contact-row i {
      font-size: 16px;
      color: var(--text-tertiary);
    }

    .contact-row a {
      color: var(--accent);
      text-decoration: none;
    }

    .contact-row a:hover {
      text-decoration: underline;
    }

    /* ── Footer ── */
    .footer {
      padding: 2rem 0 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 8px;
    }

    .footer-note {
      font-size: 12px;
      color: var(--text-tertiary);
    }

    @media (max-width: 480px) {
      .hero-name {
        font-size: 28px;
        padding-right: 80px;
      }

      .proj-header {
        flex-direction: column;
        gap: 6px;
      }

      .skills-grid {
        grid-template-columns: 1fr 1fr;
      }

      .hero-avatar {
        width: 60px;
        height: 60px;
      }
    }
  </style>
</head>

