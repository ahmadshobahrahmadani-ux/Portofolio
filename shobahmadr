  <div class="port">

    <!-- Hero -->
    <div class="hero">
      <p class="hero-tag">Portfolio</p>

      <div class="hero-avatar">
        <div class="hero-avatar-placeholder">
          <i class="ti ti-user"></i>
        </div>
      </div>

      <h1 class="hero-name">Ahmad Shobah Rahmadani</h1>
      <p class="hero-role">
        D3 Teknik Informatika · Universitas Sebelas Maret<br>
        Mahasiswa · Aktif
      </p>
      <div class="hero-badges">
